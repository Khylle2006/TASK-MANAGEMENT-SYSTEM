  <property name="styleSheet">
   <string notr="true">
/* Main background - pure white */
QMainWindow, QWidget#centralwidget, QStackedWidget, QDialog {
    background-color: #FFFFFF;
    font-family: &quot;Segoe UI&quot;, sans-serif;
}

/* All frames - white with subtle border */
QFrame {
    background-color: #FFFFFF;
    border-radius: 12px;
    border: 1px solid #E5E5E5;
}

/* Sidebar specific */
QFrame#sidebar {
    background-color: #FFFFFF;
    border-right: 1px solid #E5E5E5;
    border-radius: 0px;
}

/* Labels - consistent grayscale */
QLabel {
    color: #333333;
}

QLabel#statLabel, QLabel#label_3, QLabel#label {
    font-size: 10px;
    font-weight: 600;
    color: #666666;
}

QLabel#lblDueToday, QLabel#lblCompleted, QLabel#lblOverDue {
    font-size: 30px;
    font-weight: 700;
    color: #333333;
}

QLabel#statSub {
    font-size: 11px;
    color: #666666;
}

QLabel#cardTitle, QLabel#cardTitle_2, QLabel#cardTitle_3 {
    font-size: 13px;
    font-weight: 700;
    color: #333333;
}

QLabel#pageTitle, QLabel#pageTitle_2, QLabel#pageTitle_3 {
    font-size: 22px;
    font-weight: 700;
    color: #333333;
}

QLabel#pageSubtitle {
    font-size: 12px;
    color: #666666;
}

QLabel#newTaskLabel, QLabel#cardSectionTitle {
    font-size: 13px;
    font-weight: 700;
    color: #333333;
}

QLabel#fieldLabel, QLabel#fieldLabel_2, QLabel#fieldLabel_3, QLabel#fieldLabel_4, QLabel#fieldLabel_5 {
    font-size: 10px;
    font-weight: 600;
    color: #666666;
    letter-spacing: 1px;
}

QLabel#detailLabel {
    font-size: 12px;
    color: #666666;
}

QLabel#detailValueNormal {
    font-size: 12px;
    color: #333333;
    font-weight: 500;
}

QLabel#detailValueGreen {
    font-size: 12px;
    color: #4CAF50;
    font-weight: 600;
}

QLabel#detailValueRed {
    font-size: 12px;
    color: #F44336;
    font-weight: 600;
}

QLabel#detailValueBlue {
    font-size: 12px;
    color: #2196F3;
    font-weight: 500;
}

/* Badges - subtle gray tones */
QLabel#overdueBadge, QLabel#upcomingBadge {
    background-color: #F5F5F5;
    color: #666666;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border: none;
}

QLabel#draftBadge {
    background-color: #F5F5F5;
    color: #666666;
    border-radius: 6px;
    font-size: 11px;
    padding: 2px 8px;
    border: 1px solid #E5E5E5;
}

QLabel#tagUrgentPill {
    background-color: #F5F5F5;
    color: #666666;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border: 1px solid #E5E5E5;
}

QLabel#tagWorkPill {
    background-color: #F5F5F5;
    color: #666666;
    border-radius: 10px;
    font-size: 11px;
    padding: 3px 10px;
    border: 1px solid #E5E5E5;
}

QLabel#appTitle {
    font-size: 18px;
    font-weight: 700;
    color: #333333;
    padding: 12px 16px 4px 16px;
}

QLabel#appSub {
    font-size: 11px;
    color: #666666;
    padding: 0px 16px 16px 16px;
}

QLabel#lblUser {
    color: #666666;
    padding: 8px 16px;
}

QLabel#headerTitle {
    font-size: 22px;
    font-weight: 700;
    color: #333333;
}

QLabel#headerSubtitle {
    font-size: 12px;
    color: #666666;
}

QLabel#sectionLabel {
    font-size: 10px;
    font-weight: 600;
    color: #666666;
    letter-spacing: 1px;
}

/* Buttons - consistent styling */
QPushButton {
    background-color: #FFFFFF;
    color: #333333;
    border: 1px solid #E5E5E5;
    border-radius: 8px;
    font-size: 13px;
    padding: 8px 12px;
}

QPushButton:hover {
    background-color: #F5F5F5;
    border-color: #CCCCCC;
}

QPushButton:pressed {
    background-color: #E8E8E8;
}

QPushButton#btnNavHome, QPushButton#btnAddTask_2, QPushButton#btnPriorityView, QPushButton#btnOverallTask, QPushButton#btnOrganizeTask {
    text-align: left;
    padding: 10px 16px;
    border: none;
    border-radius: 0px;
}

QPushButton#btnNavHome:checked, QPushButton#btnAddTask_2:checked, QPushButton#btnPriorityView:checked, QPushButton#btnOverallTask:checked, QPushButton#btnOrganizeTask:checked {
    background-color: #F5F5F5;
    border-left: 3px solid #333333;
}

QPushButton#btnLogout {
    background-color: #F5F5F5;
    color: #666666;
    border: 1px solid #E5E5E5;
    border-radius: 6px;
    font-weight: bold;
    margin: 8px 16px 16px 16px;
}

QPushButton#btnLogout:hover {
    background-color: #FFEBEE;
    color: #F44336;
    border-color: #F44336;
}

QPushButton#btnAddTask {
    background-color: #F5F5F5;
    color: #666666;
    border: 1px solid #E5E5E5;
    border-radius: 6px;
    padding: 4px 12px;
    font-size: 12px;
}

QPushButton#btnCreateTask {
    background-color: #333333;
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    padding: 10px;
}

QPushButton#btnCreateTask:hover {
    background-color: #444444;
}

QPushButton#btnSaveDraft, QPushButton#btnCancel {
    background-color: #FFFFFF;
    color: #666666;
    border: 1px solid #E5E5E5;
    border-radius: 8px;
    font-size: 13px;
    padding: 10px;
}

QPushButton#btnSaveDraft:hover, QPushButton#btnCancel:hover {
    background-color: #F5F5F5;
}

QPushButton#addTagBtn, QPushButton#addSubtaskBtn {
    background-color: transparent;
    color: #666666;
    border: 1px dashed #CCCCCC;
    border-radius: 10px;
    font-size: 11px;
    padding: 3px 10px;
}

QPushButton#addTagBtn:hover, QPushButton#addSubtaskBtn:hover {
    background-color: #F5F5F5;
    border-color: #999999;
}

QPushButton#btnAddList {
    background-color: #333333;
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 20px;
}

QPushButton#btnAddList:hover {
    background-color: #444444;
}

QPushButton#btnDeleteList {
    background-color: transparent;
    color: #999999;
    border: 1px solid #E5E5E5;
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 11px;
}

QPushButton#btnDeleteList:hover {
    background-color: #FFEBEE;
    color: #F44336;
    border-color: #F44336;
}

/* Input fields - light gray background */
QLineEdit#inputField, QLineEdit#listNameInput {
    background-color: #F8F8F8;
    border: 1px solid #E5E5E5;
    border-radius: 8px;
    font-size: 13px;
    color: #333333;
    padding: 8px 12px;
}

QLineEdit#inputField:focus, QLineEdit#listNameInput:focus {
    border: 1px solid #999999;
    background-color: #FFFFFF;
}

QTextEdit#descField {
    background-color: #F8F8F8;
    border: 1px solid #E5E5E5;
    border-radius: 8px;
    font-size: 13px;
    color: #333333;
    padding: 8px 12px;
}

QTextEdit#descField:focus {
    border: 1px solid #999999;
    background-color: #FFFFFF;
}

QComboBox#comboField, QComboBox, QComboBox#sectionCombo {
    background-color: #F8F8F8;
    border: 1px solid #E5E5E5;
    border-radius: 8px;
    font-size: 13px;
    color: #333333;
    padding: 7px 12px;
}

QComboBox#comboField::drop-down, QComboBox::drop-down {
    border: none;
    width: 20px;
}

QDateEdit {
    background-color: #F8F8F8;
    border: 1px solid #E5E5E5;
    border-radius: 8px;
    font-size: 13px;
    color: #333333;
    padding: 5px 8px;
}

/* Tables */
QTableWidget {
    background-color: #FFFFFF;
    border: none;
    gridline-color: #F0F0F0;
    color: #333333;
}

QTableWidget::item {
    padding: 8px;
}

QTableWidget::item:selected {
    background-color: #F5F5F5;
    color: #333333;
}

QHeaderView::section {
    background-color: #FAFAFA;
    padding: 8px;
    border: none;
    border-bottom: 1px solid #E5E5E5;
    color: #666666;
    font-weight: 600;
}

/* List Widget */
QListWidget#listsList {
    border: 1px solid #E5E5E5;
    border-radius: 8px;
    background-color: #FFFFFF;
    outline: none;
}

QListWidget#listsList::item {
    padding: 0px;
    border-bottom: 1px solid #F0F0F0;
}

QListWidget#listsList::item:hover {
    background-color: #F8F8F8;
}

QListWidget#listsList::item:selected {
    background-color: #F5F5F5;
}

/* Frames and containers */
QFrame#mainCard, QFrame#rightCard, QFrame#statCard, QFrame#tasksCard, QFrame#overdueCard, QFrame#upcomingCard, QFrame#addListFrame {
    background-color: #FFFFFF;
    border: 1px solid #E5E5E5;
    border-radius: 12px;
}

QFrame#addListFrame {
    background-color: #F8F8F8;
}

QFrame#listsContainer {
    background-color: #FFFFFF;
    border: 1px solid #E5E5E5;
    border-radius: 8px;
}

QFrame#frame, QFrame#frame_2 {
    color: #E5E5E5;
    border: none;
    border-top: 1px solid #E5E5E5;
}


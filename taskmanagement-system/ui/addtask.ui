  <property name="styleSheet">
   <string notr="true">
QDialog, QWidget#centralwidget {
    background-color: #F2F2F0;
    font-family: &quot;Segoe UI&quot;, sans-serif;
}
QLabel#pageTitle {
    font-size: 22px;
    font-weight: 700;
    color: #1A1A1A;
}
QLabel#pageSubtitle {
    font-size: 12px;
    color: #888888;
}
QFrame#mainCard {
    background-color: #FFFFFF;
    border-radius: 12px;
    border: 1px solid #E5E5E3;
}
QFrame#rightCard {
    background-color: #FFFFFF;
    border-radius: 12px;
    border: 1px solid #E5E5E3;
}
QLabel#cardSectionTitle {
    font-size: 13px;
    font-weight: 700;
    color: #1A1A1A;
}
QLabel#newTaskLabel {
    font-size: 13px;
    font-weight: 700;
    color: #1A1A1A;
}
QLabel#draftBadge {
    background-color: #F0F0EE;
    color: #666666;
    border-radius: 6px;
    font-size: 11px;
    padding: 2px 8px;
    border: 1px solid #E0E0DE;
}
QLabel#fieldLabel {
    font-size: 10px;
    font-weight: 600;
    color: #AAAAAA;
    letter-spacing: 1px;
}
QLineEdit#inputField {
    background-color: #F5F5F3;
    border: 1px solid #E5E5E3;
    border-radius: 8px;
    font-size: 13px;
    color: #1A1A1A;
    padding: 8px 12px;
    selection-background-color: #1A1A1A;
}
QLineEdit#inputField:focus {
    border: 1px solid #AAAAAA;
}
QTextEdit#descField {
    background-color: #F5F5F3;
    border: 1px solid #E5E5E3;
    border-radius: 8px;
    font-size: 13px;
    color: #444444;
    padding: 8px 12px;
}
QTextEdit#descField:focus {
    border: 1px solid #AAAAAA;
}
QComboBox#comboField {
    background-color: #F5F5F3;
    border: 1px solid #E5E5E3;
    border-radius: 8px;
    font-size: 13px;
    color: #1A1A1A;
    padding: 7px 12px;
}
QComboBox#comboField::drop-down {
    border: none;
    width: 20px;
}
QComboBox#listCombo {
    background-color: #F5F5F3;
    border: 1px solid #E5E5E3;
    border-radius: 8px;
    font-size: 13px;
    color: #1A1A1A;
    padding: 7px 12px;
}
QComboBox#listCombo::drop-down {
    border: none;
    width: 20px;
}
QPushButton#btnRefreshLists {
    background-color: transparent;
    color: #888888;
    border: 1px solid #E5E5E3;
    border-radius: 8px;
    font-size: 11px;
    padding: 7px 12px;
}
QPushButton#btnRefreshLists:hover {
    background-color: #F5F5F3;
}
QPushButton#priorityHigh {
    background-color: #FDECEA;
    color: #D93025;
    border: 2px solid #D93025;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    padding: 10px;
}
QPushButton#priorityMed {
    background-color: #FFFFFF;
    color: #E6A817;
    border: 1px solid #E5E5E3;
    border-radius: 8px;
    font-size: 12px;
    padding: 10px;
}
QPushButton#priorityMed:hover {
    background-color: #FFF8E1;
    border-color: #E6A817;
}
QPushButton#priorityLow {
    background-color: #FFFFFF;
    color: #1A8A4A;
    border: 1px solid #E5E5E3;
    border-radius: 8px;
    font-size: 12px;
    padding: 10px;
}
QPushButton#priorityLow:hover {
    background-color: #E8F5E9;
    border-color: #1A8A4A;
}
QFrame#tagsBox {
    background-color: #F5F5F3;
    border: 1px solid #E5E5E3;
    border-radius: 8px;
    min-height: 44px;
}
QLabel#tagUrgentPill {
    background-color: #FDECEA;
    color: #D93025;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border: 1px solid #F5C6C2;
}
QLabel#tagWorkPill {
    background-color: #E3F2FD;
    color: #1565C0;
    border-radius: 10px;
    font-size: 11px;
    padding: 3px 10px;
    border: 1px solid #BBDEFB;
}
QPushButton#addTagBtn {
    background-color: transparent;
    color: #888888;
    border: 1px dashed #CCCCCC;
    border-radius: 10px;
    font-size: 11px;
    padding: 3px 10px;
}
QPushButton#addTagBtn:hover {
    background-color: #F0F0EE;
}
QPushButton#btnSaveDraft {
    background-color: #FFFFFF;
    color: #444444;
    border: 1px solid #D8D8D6;
    border-radius: 8px;
    font-size: 13px;
    padding: 10px;
}
QPushButton#btnSaveDraft:hover {
    background-color: #F5F5F3;
}
QPushButton#btnCreateTask {
    background-color: #1A1A1A;
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    padding: 10px;
}
QPushButton#btnCreateTask:hover {
    background-color: #333333;
}
QFrame#subtaskRow {
    background-color: #F5F5F3;
    border-radius: 7px;
    border: 1px solid #E5E5E3;
}
QLabel#subtaskTextDone {
    font-size: 12px;
    color: #AAAAAA;
    text-decoration: line-through;
}
QLabel#subtaskText {
    font-size: 12px;
    color: #1A1A1A;
}
QPushButton#addSubtaskBtn {
    background-color: transparent;
    color: #888888;
    border: 1px dashed #CCCCCC;
    border-radius: 7px;
    font-size: 11px;
    padding: 6px;
    text-align: left;
}
QPushButton#addSubtaskBtn:hover {
    background-color: #F0F0EE;
}
QProgressBar#subtaskProgress {
    background-color: #E5E5E3;
    border: none;
    border-radius: 3px;
    max-height: 5px;
}
QProgressBar#subtaskProgress::chunk {
    background-color: #1A8A4A;
    border-radius: 3px;
}
QLabel#progressLabel {
    font-size: 10px;
    color: #888888;
}
QLabel#detailLabel {
    font-size: 12px;
    color: #888888;
}
QLabel#detailValueNormal {
    font-size: 12px;
    color: #1A1A1A;
    font-weight: 500;
}
QLabel#detailValueGreen {
    font-size: 12px;
    color: #1A8A4A;
    font-weight: 600;
}
QLabel#detailValueRed {
    font-size: 12px;
    color: #D93025;
    font-weight: 600;
}
QLabel#detailValueBlue {
    font-size: 12px;
    color: #2563EB;
    font-weight: 500;
}
QLabel#detailDotHigh {
    background-color: #D93025;
    border-radius: 5px;
    min-width: 8px;
    max-width: 8px;
    min-height: 8px;
    max-height: 8px;
}
QLabel#detailDotBlue {
    background-color: #2563EB;
    border-radius: 5px;
    min-width: 8px;
    max-width: 8px;
    min-height: 8px;
    max-height: 8px;
}
QCheckBox {
    spacing: 0px;
}
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border-radius: 8px;
    border: 2px solid #D0D0CE;
    background: white;
}
QCheckBox::indicator:checked {
    background-color: #1A8A4A;
    border-color: #1A8A4A;
}
